# .env
# 환경변수 설정 파일

# ============================================
# 🆕 자바단 DB 연결 설정
# ============================================
DB_HOST=your-java-db-host.com
DB_PORT=3306
DB_USER=rag_user
DB_PASSWORD=your-strong-password
DB_NAME=nuclear_rag

# ============================================
# 🆕 RAG 워크플로우 설정
# ============================================
RAG_AUTO_PROCESS=true              # 자동 처리 활성화 (true/false)
RAG_POLLING_INTERVAL=60            # 폴링 주기 (초)
RAG_BATCH_SIZE=10                  # 한 번에 처리할 파일 수
RAG_RESET_COLLECTION=0             # Milvus 컬렉션 리셋 (1=리셋, 0=유지)

# ============================================
# 청킹 설정
# ============================================
CHUNK_TARGET_TOKENS=400            # 목표 청크 토큰 수
CHUNK_OVERLAP_TOKENS=100           # 오버랩 토큰 수

# ============================================
# MinIO 설정 (기존 유지)
# ============================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_PRESIGN_SCHEME=https
MINIO_PRESIGN_HOST=gateway.example.com
MINIO_PRESIGN_PATH_PREFIX=/minio

# ============================================
# Milvus 설정 (기존 유지)
# ============================================
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=rag_chunks_m3_v2

# Milvus 스키마 제약
MILVUS_SECTION_MAX=512
MILVUS_DOCID_MAX=256
MILVUS_CHUNK_MAX=8192
RAG_SECTION_MAX=200

# Milvus 인덱스 설정
MILVUS_INDEX_TYPE=HNSW
MILVUS_METRIC_TYPE=IP
MILVUS_HNSW_M=16
MILVUS_HNSW_EFCON=200
MILVUS_EF_SEARCH=384
MILVUS_EF_PER_K=8
MILVUS_EF_MAX=2048

# ============================================
# 검색 설정 (기존 유지)
# ============================================
RAG_TOP_K=20
RAG_RERANK_TOP_K=5
RAG_HYBRID_ALPHA=0.7
RAG_BM25_K1=1.5
RAG_BM25_B=0.75

# ============================================
# LLM 설정 (기존 유지)
# ============================================
VLLM_HOST=vllm-a4000
VLLM_PORT=8000
VLLM_MODEL_NAME=llama-3.2-3b
VLLM_MAX_TOKENS=2048
VLLM_TEMPERATURE=0.1

# ============================================
# Hugging Face 설정 (기존 유지)
# ============================================
HUGGINGFACE_TOKEN=your-hf-token-here